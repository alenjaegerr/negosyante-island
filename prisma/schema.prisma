generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  business_pending
  business_verified
  admin
}

enum VerificationStatus {
  pending
  approved
  rejected
}

enum DocumentType {
  bir_tin
  mayor_permit
}

enum TrendCategory {
  tiktok
  the_internet
  youtube
  facebook
  reddit
  x
  instagram
}

model User {
  id                    String                @id @default(cuid())
  name                  String
  email                 String                @unique
  passwordHash          String
  role                  Role                  @default(user)
  businessName          String?
  avatarUrl             String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  posts                 Post[]
  verificationRequests  VerificationRequest[] @relation("BusinessRequests")
  reviewedRequests      VerificationRequest[] @relation("ReviewedBy")
  businessFollows       BusinessFollow[]
  businessMessages      BusinessMessage[]
  businessFeedLikes     BusinessFeedLike[]
  businessFeedComments  BusinessFeedComment[]
  notifications         Notification[]
}

model Post {
  id        String   @id @default(cuid())
  content   String
  tags      String[]
  likes     Int      @default(0)
  comments  Int      @default(0)
  shares    Int      @default(0)
  views     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])

  @@index([createdAt])
}

model VerificationRequest {
  id            String             @id @default(cuid())
  businessName  String
  documentType  DocumentType
  documentUrl   String
  status        VerificationStatus @default(pending)
  createdAt     DateTime           @default(now())
  reviewedAt    DateTime?
  rejectionNote String?
  userId        String
  reviewerId    String?
  user          User               @relation("BusinessRequests", fields: [userId], references: [id])
  reviewer      User?              @relation("ReviewedBy", fields: [reviewerId], references: [id])

  @@index([status])
}

model Trend {
  id                String   @id @default(cuid())
  keyword           String   @unique
  engagementPercent Float
  views             Int
  growthPercent     Float
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model TrendingPost {
  id             String        @id @default(cuid())
  title          String
  category       TrendCategory
  snippet        String
  content        String
  imageUrl       String?
  videoUrl       String?
  videoLoopSeconds Int         @default(5)
  isDraft        Boolean       @default(false)
  isInsightReady Boolean       @default(true)
  insightTitle   String?
  insightBody    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([category, createdAt])
}

model BusinessFollow {
  id           String   @id @default(cuid())
  businessSlug String
  createdAt    DateTime @default(now())
  userId       String
  user         User     @relation(fields: [userId], references: [id])

  @@unique([userId, businessSlug])
  @@index([businessSlug])
}

model BusinessMessage {
  id            String   @id @default(cuid())
  businessSlug  String
  senderName    String
  senderAge     Int
  actionOption  String
  note          String
  createdAt     DateTime @default(now())
  senderUserId  String?
  senderUser    User?    @relation(fields: [senderUserId], references: [id])

  @@index([businessSlug])
}

model BusinessFeedLike {
  id           String   @id @default(cuid())
  businessSlug String
  postId       String
  createdAt    DateTime @default(now())
  userId       String
  user         User     @relation(fields: [userId], references: [id])

  @@unique([userId, businessSlug, postId])
  @@index([businessSlug, postId])
}

model BusinessFeedComment {
  id           String   @id @default(cuid())
  businessSlug String
  postId       String
  content      String
  authorName   String
  createdAt    DateTime @default(now())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])

  @@index([businessSlug, postId])
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String
  href      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, isRead, createdAt])
}
