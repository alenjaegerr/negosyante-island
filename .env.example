# Required in every environment
DATABASE_URL="postgresql://user:password@localhost:5432/negosyante_island"
# Optional: Prisma Data Proxy URL (recommended for serverless deployments)
# PRISMA_DATA_PROXY_URL="prisma://<your-data-proxy-url>"
JWT_SECRET="replace-with-a-strong-secret"

# Public app URL used for metadata and redirects
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# SMTP for verification and reset emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="business.negosyanteisland@gmail.com"
SMTP_PASS="your-gmail-app-password"
SMTP_FROM="Negosyante Island <business.negosyanteisland@gmail.com>"

# Optional: SendGrid (recommended for production/serverless)
SENDGRID_API_KEY=""
SENDGRID_FROM="no-reply@yourdomain.com"

# Optional: Prisma Data Proxy (recommended for serverless DB connection pooling)
# Set PRISMA_DATA_PROXY_URL when using Prisma Data Proxy
PRISMA_DATA_PROXY_URL=""
